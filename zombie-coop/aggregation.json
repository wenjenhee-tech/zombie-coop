[
  {
    "name": "getTaskStats",
    "file": "backend/controllers/congViecGiaoController.js",
    "collection": "CongViecGiao",
    "pipeline": [
      {
        "$group": {
          "_id": null,
          "totalTasks": {
            "$sum": 1
          },
          "completedTasks": {
            "$sum": {
              "$cond": [
                {
                  "$eq": [
                    "$trang_thai",
                    "Hoàn thành"
                  ]
                },
                1,
                0
              ]
            }
          },
          "inProgressTasks": {
            "$sum": {
              "$cond": [
                {
                  "$eq": [
                    "$trang_thai",
                    "Đang thực hiện"
                  ]
                },
                1,
                0
              ]
            }
          },
          "overdueTasks": {
            "$sum": {
              "$cond": [
                {
                  "$and": [
                    {
                      "$lt": [
                        "$ngay_ket_thuc_du_kien",
                        "__NOW__"
                      ]
                    },
                    {
                      "$nin": [
                        "$trang_thai",
                        [
                          "Hoàn thành",
                          "Hủy bỏ"
                        ]
                      ]
                    }
                  ]
                },
                1,
                0
              ]
            }
          },
          "avgProgress": {
            "$avg": "$tien_do"
          }
        }
      }
    ],
    "notes": "__NOW__ tương ứng new Date() trong code."
  },
  {
